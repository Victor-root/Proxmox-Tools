LANG_CODES=(
    ar ca da de en es eu fa fr gl he hu it ja kr nb nl nn pl pt_BR ru sl sv tr zh_CN zh_TW
)

is_supported_code() {
    local code="$1"
    local item

    for item in "${LANG_CODES[@]}"; do
        [[ "$item" == "$code" ]] && return 0
    done

    return 1
}

normalize_locale_to_code() {
    local raw="$1"

    raw="${raw%%.*}"
    raw="${raw,,}"
    raw="${raw/-/_}"

    case "$raw" in
        ar*) echo "ar" ;;
        ca*) echo "ca" ;;
        da*) echo "da" ;;
        de*) echo "de" ;;
        es*) echo "es" ;;
        eu*) echo "eu" ;;
        fa*) echo "fa" ;;
        fr*) echo "fr" ;;
        gl*) echo "gl" ;;
        he*|iw*) echo "he" ;;
        hu*) echo "hu" ;;
        it*) echo "it" ;;
        ja*) echo "ja" ;;
        ko*|kr*) echo "kr" ;;
        nb*) echo "nb" ;;
        nn*) echo "nn" ;;
        nl*) echo "nl" ;;
        pl*) echo "pl" ;;
        pt_br*) echo "pt_BR" ;;
        pt*) echo "pt_BR" ;;
        ru*) echo "ru" ;;
        sl*) echo "sl" ;;
        sv*) echo "sv" ;;
        tr*) echo "tr" ;;
        zh_cn*) echo "zh_CN" ;;
        zh_tw*) echo "zh_TW" ;;
        zh*) echo "zh_CN" ;;
        en*) echo "en" ;;
        *) echo "en" ;;
    esac
}

read_server_lang_raw() {
    local raw=""

    if [[ -f "$DEFAULT_LOCALE_FILE" ]]; then
        raw="$(awk -F= '
            /^LANG=/ {
                gsub(/"/, "", $2)
                print $2
                exit
            }
        ' "$DEFAULT_LOCALE_FILE" 2>/dev/null || true)"
    fi

    if [[ -z "$raw" ]]; then
        raw="${LANG:-${LC_MESSAGES:-en}}"
    fi

    echo "$raw"
}

APP_LANG="en"

detect_lang() {
    local raw code

    raw="$(read_server_lang_raw)"
    code="$(normalize_locale_to_code "$raw")"

    if is_supported_code "$code" && [[ -n "${I18N["$code:script_title"]:-}" ]]; then
        APP_LANG="$code"
    else
        APP_LANG="en"
    fi
}

tr_msg() {
    local key="$1"
    printf '%s\n' "${I18N["$APP_LANG:$key"]:-${I18N["en:$key"]:-$key}}"
}

# ------------------------------------------------------------
# Colors (Proxmox-inspired) — same visual engine as
# lxc-wireguard-server-install.sh, orange as the accent color.
# ------------------------------------------------------------
if [[ -t 1 ]]; then
    RESET='\033[0m'
    BOLD='\033[1m'
    DIM='\033[2m'
    PMX_ORANGE='\033[38;5;166m'
    PMX_ORANGE_DARK='\033[38;5;130m'
    PMX_ORANGE_SOFT='\033[38;5;208m'
    PMX_RED='\033[38;5;124m'
    PMX_AMBER='\033[38;5;214m'
    PMX_GREEN='\033[38;5;70m'
    PMX_CYAN='\033[38;5;73m'
    PMX_BLUE='\033[38;5;67m'
    PMX_GREY='\033[38;5;244m'
else
    RESET=''
    BOLD=''
    DIM=''
    PMX_ORANGE=''
    PMX_ORANGE_DARK=''
    PMX_ORANGE_SOFT=''
    PMX_RED=''
    PMX_AMBER=''
    PMX_GREEN=''
    PMX_CYAN=''
    PMX_BLUE=''
    PMX_GREY=''
fi

term_width() {
    local cols
    cols="$(tput cols 2>/dev/null || echo 80)"
    [[ -z "$cols" || "$cols" -lt 50 ]] && cols=80
    [[ "$cols" -gt 92 ]] && cols=92
    echo "$cols"
}

hr() {
    local cols
    cols="$(term_width)"
    printf "%b" "${PMX_ORANGE_DARK}"
    printf "%*s\n" "$cols" "" | tr ' ' '─'
    printf "%b" "${RESET}"
}

rule() { hr; }

panel() {
    local color="$1"
    local title="$2"
    shift 2

    echo
    printf "%b┌%b %b%b%s%b\n" "$color" "$RESET" "$BOLD" "$color" "$title" "$RESET"
    while (($#)); do
        printf "%b│%b %b\n" "$color" "$RESET" "$1"
        shift
    done
    printf "%b└%b\n" "$color" "$RESET"
}

say_info() { printf "%b›%b %b\n" "${PMX_ORANGE_SOFT}" "${RESET}" "$*"; }
say_ok()   { printf "%b✓%b %b\n" "${PMX_GREEN}" "${RESET}" "$*"; }
say_err()  { printf "%b✗%b %b\n" "${PMX_RED}" "${RESET}" "$*" >&2; }

prompt_default() {
    local label="$1"
    local default="$2"
    local value

    printf "%b?%b %b%s%b %b[%s]%b : " \
        "${PMX_ORANGE_SOFT}" "${RESET}" \
        "${BOLD}" "$label" "${RESET}" \
        "${DIM}" "$default" "${RESET}" >&2

    IFS= read -r value
    printf "%s" "${value:-$default}"
}

native_lang_name() {
    case "$1" in
        ar) echo "العربية" ;;
        ca) echo "Català" ;;
        da) echo "Dansk" ;;
        de) echo "Deutsch" ;;
        en) echo "English" ;;
        es) echo "Español" ;;
        eu) echo "Euskara" ;;
        fa) echo "فارسی" ;;
        fr) echo "Français" ;;
        gl) echo "Galego" ;;
        he) echo "עברית" ;;
        hu) echo "Magyar" ;;
        it) echo "Italiano" ;;
        ja) echo "日本語" ;;
        kr) echo "한국어" ;;
        nb) echo "Norsk bokmål" ;;
        nl) echo "Nederlands" ;;
        nn) echo "Norsk nynorsk" ;;
        pl) echo "Polski" ;;
        pt_BR) echo "Português do Brasil" ;;
        ru) echo "Русский" ;;
        sl) echo "Slovenščina" ;;
        sv) echo "Svenska" ;;
        tr) echo "Türkçe" ;;
        zh_CN) echo "简体中文" ;;
        zh_TW) echo "繁體中文" ;;
        *) echo "$1" ;;
    esac
}

locale_for_code() {
    case "$1" in
        ar) echo "ar_SA.UTF-8" ;;
        ca) echo "ca_ES.UTF-8" ;;
        da) echo "da_DK.UTF-8" ;;
        de) echo "de_DE.UTF-8" ;;
        en) echo "en_US.UTF-8" ;;
        es) echo "es_ES.UTF-8" ;;
        eu) echo "eu_ES.UTF-8" ;;
        fa) echo "fa_IR.UTF-8" ;;
        fr) echo "fr_FR.UTF-8" ;;
        gl) echo "gl_ES.UTF-8" ;;
        he) echo "he_IL.UTF-8" ;;
        hu) echo "hu_HU.UTF-8" ;;
        it) echo "it_IT.UTF-8" ;;
        ja) echo "ja_JP.UTF-8" ;;
        kr) echo "ko_KR.UTF-8" ;;
        nb) echo "nb_NO.UTF-8" ;;
        nl) echo "nl_NL.UTF-8" ;;
        nn) echo "nn_NO.UTF-8" ;;
        pl) echo "pl_PL.UTF-8" ;;
        pt_BR) echo "pt_BR.UTF-8" ;;
        ru) echo "ru_RU.UTF-8" ;;
        sl) echo "sl_SI.UTF-8" ;;
        sv) echo "sv_SE.UTF-8" ;;
        tr) echo "tr_TR.UTF-8" ;;
        zh_CN) echo "zh_CN.UTF-8" ;;
        zh_TW) echo "zh_TW.UTF-8" ;;
        *) echo "" ;;
    esac
}

language_priority_for_code() {
    case "$1" in
        pt_BR) echo "pt_BR:pt" ;;
        zh_CN) echo "zh_CN:zh" ;;
        zh_TW) echo "zh_TW:zh" ;;
        kr) echo "ko_KR:ko" ;;
        en) echo "en_US:en" ;;
        *) echo "$(locale_for_code "$1" | cut -d. -f1):${1%%_*}" ;;
    esac
}

timezone_for_code() {
    case "$1" in
        ar) echo "Asia/Riyadh" ;;
        ca|es|eu|gl) echo "Europe/Madrid" ;;
        da) echo "Europe/Copenhagen" ;;
        de) echo "Europe/Berlin" ;;
        en) echo "UTC" ;;
        fa) echo "Asia/Tehran" ;;
        fr) echo "Europe/Paris" ;;
        he) echo "Asia/Jerusalem" ;;
        hu) echo "Europe/Budapest" ;;
        it) echo "Europe/Rome" ;;
        ja) echo "Asia/Tokyo" ;;
        kr) echo "Asia/Seoul" ;;
        nb|nn) echo "Europe/Oslo" ;;
        nl) echo "Europe/Amsterdam" ;;
        pl) echo "Europe/Warsaw" ;;
        pt_BR) echo "America/Sao_Paulo" ;;
        ru) echo "Europe/Moscow" ;;
        sl) echo "Europe/Ljubljana" ;;
        sv) echo "Europe/Stockholm" ;;
        tr) echo "Europe/Istanbul" ;;
        zh_CN) echo "Asia/Shanghai" ;;
        zh_TW) echo "Asia/Taipei" ;;
        *) echo "UTC" ;;
    esac
}

detect_default_code() {
    normalize_locale_to_code "$(read_server_lang_raw)"
}

show_ssh_warning() {
    panel "$PMX_AMBER" "$(tr_msg ssh_warning_title)" \
        "$(tr_msg ssh_warning_body)" \
        "$(tr_msg latest_backup_hint): $(tr_msg menu_option_2)"
    echo
}

banner() {
    clear || true
    echo
    printf "%b%s%b\n" "${PMX_ORANGE}" '██████╗ ██████╗  ██████╗ ██╗  ██╗███╗   ███╗ ██████╗ ██╗  ██╗' "${RESET}"
    printf "%b%s%b\n" "${PMX_ORANGE}" '██╔══██╗██╔══██╗██╔═══██╗╚██╗██╔╝████╗ ████║██╔═══██╗╚██╗██╔╝' "${RESET}"
    printf "%b%s%b\n" "${PMX_ORANGE}" '██████╔╝██████╔╝██║   ██║ ╚███╔╝ ██╔████╔██║██║   ██║ ╚███╔╝ ' "${RESET}"
    printf "%b%s%b\n" "${PMX_ORANGE}" '██╔═══╝ ██╔══██╗██║   ██║ ██╔██╗ ██║╚██╔╝██║██║   ██║ ██╔██╗ ' "${RESET}"
    printf "%b%s%b\n" "${PMX_ORANGE}" '██║     ██║  ██║╚██████╔╝██╔╝ ██╗██║ ╚═╝ ██║╚██████╔╝██╔╝ ██╗' "${RESET}"
    printf "%b%s%b\n" "${PMX_ORANGE}" '╚═╝     ╚═╝  ╚═╝ ╚═════╝ ╚═╝  ╚═╝╚═╝     ╚═╝ ╚═════╝ ╚═╝  ╚═╝' "${RESET}"
    echo
    printf "  %b%s%b %b· by Victor-root%b\n" "${BOLD}${PMX_ORANGE_SOFT}" "$1" "${RESET}" "${PMX_GREY}" "${RESET}"
    hr
}

show_banner() {
    banner "$(tr_msg script_title)"

    panel "$PMX_BLUE" "$(tr_msg repo_hint)" \
        "$(tr_msg label_host): ${BOLD}$(hostname)${RESET}" \
        "$(tr_msg detected_language): ${BOLD}$(native_lang_name "$APP_LANG")${RESET}"
    echo

    show_ssh_warning
}

pause() {
    echo
    read -r -p "$(tr_msg press_enter)" _
}

require_root() {
    if [[ "${EUID:-$(id -u)}" -ne 0 ]]; then
        say_err "$(tr_msg running_as_root)"
        exit 1
    fi
}

require_commands() {
    local cmd
    for cmd in locale locale-gen update-locale timedatectl systemctl sed awk grep date find sort tail cp mkdir chmod mktemp cat cut seq rm touch hostname; do
        command -v "$cmd" >/dev/null 2>&1 || { say_err "$(tr_msg missing_command): $cmd"; exit 1; }
    done
}

require_files() {
    [[ -f "$LOCALE_GEN_FILE" ]] || { say_err "$(tr_msg file_not_found): $LOCALE_GEN_FILE"; exit 1; }
    [[ -d "/etc/pve" ]] || { say_err "$(tr_msg directory_not_found): /etc/pve"; exit 1; }
}

show_warning_and_confirm() {
    panel "$PMX_AMBER" "$(tr_msg warning_title)" \
        "$(tr_msg warning_body_1)" \
        "$(tr_msg warning_body_2)" \
        "$(tr_msg warning_body_3)" \
        "$(tr_msg warning_body_4)"
    echo

    local answer
    printf "%b?%b %b%s%b : " "${PMX_AMBER}" "${RESET}" "${BOLD}" "$(tr_msg type_yes)" "${RESET}"
    read -r answer

    if [[ "$answer" != "yes" ]]; then
        say_info "$(tr_msg cancelled)"
        return 1
    fi

    return 0
}

latest_backup_dir() {
    find /root -maxdepth 1 -type d -name 'pve-default-language-*' | sort | tail -n1
}

list_backups_raw() {
    find /root -maxdepth 1 -type d -name 'pve-default-language-*' | sort
}

backup_file() {
    local src="$1"
    local dir="$2"
    local safe

    safe="${src#/}"
    safe="${safe//\//__}"

    if [[ -e "$src" ]]; then
        cp -a "$src" "$dir/$safe"
        echo "present:$src:$safe" >> "$dir/MANIFEST.txt"
    else
        echo "absent:$src:$safe" >> "$dir/MANIFEST.txt"
    fi
}

create_backup() {
    local ts dir

    ts="$(date +%F-%H%M%S)"
    dir="${PATCH_PREFIX}-${ts}"

    mkdir -p "$dir"
    : > "$dir/MANIFEST.txt"

    backup_file "$LOCALE_GEN_FILE" "$dir"
    backup_file "$DEFAULT_LOCALE_FILE" "$dir"
    backup_file "$DATACENTER_CFG" "$dir"
    backup_file "$PROFILE_LOCALE_FILE" "$dir"
    backup_file "$TIMEZONE_FILE" "$dir"

    {
        echo "created_at=$(date --iso-8601=seconds)"
        echo "hostname=$(hostname)"
        echo "locale_gen_file=$LOCALE_GEN_FILE"
        echo "default_locale_file=$DEFAULT_LOCALE_FILE"
        echo "datacenter_cfg=$DATACENTER_CFG"
        echo "profile_locale_file=$PROFILE_LOCALE_FILE"
        echo "timezone=$(timedatectl show -p Timezone --value 2>/dev/null || true)"
        echo
        pveversion -v 2>/dev/null || true
    } > "$dir/INFO.txt"

    echo "$dir"
}

restore_from_manifest() {
    local dir="$1"
    local status src safe

    [[ -f "$dir/MANIFEST.txt" ]] || { say_err "$(tr_msg file_not_found): $dir/MANIFEST.txt"; return 1; }

    while IFS=: read -r status src safe; do
        [[ -n "${src:-}" ]] || continue

        if [[ "$status" == "present" ]]; then
            [[ -f "$dir/$safe" || -d "$dir/$safe" ]] || { say_err "$(tr_msg file_not_found): $dir/$safe"; return 1; }
            cp -a "$dir/$safe" "$src"
        elif [[ "$status" == "absent" ]]; then
            rm -f "$src"
        fi
    done < "$dir/MANIFEST.txt"

    say_info "$(tr_msg restart_proxy)"
    systemctl restart pveproxy.service

    if command -v timedatectl >/dev/null 2>&1 && [[ -f "$TIMEZONE_FILE" ]]; then
        timedatectl set-timezone "$(cat "$TIMEZONE_FILE")" >/dev/null 2>&1 || true
    fi

    say_ok "$(tr_msg restore_done): ${PMX_CYAN}${dir}${RESET}"
}

restore_latest() {
    local dir
    dir="$(latest_backup_dir)"

    if [[ -z "$dir" ]]; then
        say_err "$(tr_msg no_backup_found)"
        return 1
    fi

    restore_from_manifest "$dir"
}

interactive_restore_menu() {
    mapfile -t backups < <(list_backups_raw)

    if [[ "${#backups[@]}" -eq 0 ]]; then
        say_err "$(tr_msg no_backup_found)"
        pause
        return
    fi

    local lines=()
    local i=1
    local b

    for b in "${backups[@]}"; do
        lines+=("${PMX_ORANGE_SOFT}${i})${RESET} ${b}")
        ((i++))
    done

    lines+=("${PMX_GREY}q) $(tr_msg cancelled)${RESET}")

    panel "$PMX_ORANGE" "$(tr_msg available_backups)" "${lines[@]}"
    echo

    local choice
    read -r -p "$(tr_msg choose_backup_number): " choice

    if [[ "$choice" == "q" || "$choice" == "Q" ]]; then
        say_info "$(tr_msg restore_cancelled)"
        pause
        return
    fi

    if ! [[ "$choice" =~ ^[0-9]+$ ]]; then
        say_err "$(tr_msg invalid_choice)"
        pause
        return
    fi

    if (( choice < 1 || choice > ${#backups[@]} )); then
        say_err "$(tr_msg selection_out_of_range)"
        pause
        return
    fi

    restore_from_manifest "${backups[$((choice-1))]}"
    pause
}

show_backups() {
    panel "$PMX_ORANGE" "$(tr_msg available_backups)"
    echo
    list_backups_raw || true
    pause
}

show_languages() {
    panel "$PMX_ORANGE" "$(tr_msg supported_languages)"
    echo

    local code
    for code in "${LANG_CODES[@]}"; do
        printf " %b%-6s%b %-24s %b%s%b\n" \
            "${PMX_ORANGE_SOFT}" "$code" "${RESET}" \
            "$(native_lang_name "$code")" \
            "${PMX_GREY}" "$(locale_for_code "$code")" "${RESET}"
    done
}

ensure_locale_gen_entry() {
    local locale_name="$1"
    local tmp

    tmp="$(mktemp)"

    awk -v loc="$locale_name" -v line="$locale_name UTF-8" '
        BEGIN { found=0 }
        {
            raw=$0
            sub(/^[[:space:]]*#?[[:space:]]*/, "", raw)
            split(raw, parts, /[[:space:]]+/)

            if (parts[1] == loc) {
                if (!found) {
                    print line
                }

                found=1
                next
            }

            print $0
        }
        END {
            if (!found) {
                print line
            }
        }
    ' "$LOCALE_GEN_FILE" > "$tmp"

    cat "$tmp" > "$LOCALE_GEN_FILE"
    rm -f "$tmp"
}

set_system_locale() {
    local locale_name="$1"
    local lang_priority="$2"

    ensure_locale_gen_entry "$locale_name"
    locale-gen

    update-locale LANG="$locale_name" LANGUAGE="$lang_priority"

    # Remove old global LC_* overrides.
    # LC_ALL must not be permanently set because it overrides LANG and all LC_* categories.
    if [[ -f "$DEFAULT_LOCALE_FILE" ]]; then
        sed -i '/^LC_ALL=/d;/^LC_[A-Z_]*=/d' "$DEFAULT_LOCALE_FILE"
    fi

    cat > "$PROFILE_LOCALE_FILE" <<EOF_PROFILE
# Managed by Proxmox-Tools pve-default-language.sh
# LC_ALL is deliberately unset because it overrides LANG and all LC_* categories.

unset LC_ALL
unset LC_CTYPE
unset LC_NUMERIC
unset LC_TIME
unset LC_COLLATE
unset LC_MONETARY
unset LC_MESSAGES
unset LC_PAPER
unset LC_NAME
unset LC_ADDRESS
unset LC_TELEPHONE
unset LC_MEASUREMENT
unset LC_IDENTIFICATION

export LANG="$locale_name"
export LANGUAGE="$lang_priority"
EOF_PROFILE

    chmod 0644 "$PROFILE_LOCALE_FILE"
}

set_web_language() {
    local code="$1"

    touch "$DATACENTER_CFG"

    if grep -Eq '^[[:space:]]*language:' "$DATACENTER_CFG"; then
        sed -i -E "s/^[[:space:]]*language:.*/language: $code/" "$DATACENTER_CFG"
    else
        if [[ -s "$DATACENTER_CFG" ]]; then
            printf '
' >> "$DATACENTER_CFG"
        fi

        printf 'language: %s
' "$code" >> "$DATACENTER_CFG"
    fi
}

set_timezone_and_ntp() {
    local timezone="$1"
    timedatectl set-timezone "$timezone"
    timedatectl set-ntp true
}

current_datacenter_language() {
    if [[ -f "$DATACENTER_CFG" ]]; then
        awk '/^[[:space:]]*language:/ { print $2; found=1 } END { if (!found) print "" }' "$DATACENTER_CFG"
    fi
}

current_default_locale() {
    if [[ -f "$DEFAULT_LOCALE_FILE" ]]; then
        awk -F= '/^LANG=/ { gsub(/"/, "", $2); print $2; found=1 } END { if (!found) print "" }' "$DEFAULT_LOCALE_FILE"
    fi
}

current_default_lc_all() {
    if [[ -f "$DEFAULT_LOCALE_FILE" ]]; then
        awk -F= '/^LC_ALL=/ { gsub(/"/, "", $2); print $2; found=1 } END { if (!found) print "" }' "$DEFAULT_LOCALE_FILE"
    fi
}

is_yes() {
    local answer="${1,,}"
    case "$answer" in
        y|yes|o|oui|s|si|sí|j|ja|e|evet|t|tak|d|da|i|igen|b|bai|a|ano|是|да) return 0 ;;
        *) return 1 ;;
    esac
}

choose_and_apply() {
    local detected_code code locale_name lang_priority timezone default_timezone current_timezone answer backup_dir

    detected_code="$(detect_default_code)"

    show_languages
    echo
    say_info "$(tr_msg detected_default): $detected_code ($(native_lang_name "$detected_code"), $(locale_for_code "$detected_code"))"
    echo

    code="$(prompt_default "$(tr_msg choose_language)" "$detected_code")"

    if ! is_supported_code "$code"; then
        say_err "$(tr_msg unsupported_language): $code"
        pause
        return
    fi

    locale_name="$(locale_for_code "$code")"
    locale_name="$(prompt_default "$(tr_msg choose_locale)" "$locale_name")"

    default_timezone="$(timezone_for_code "$code")"
    current_timezone="$(timedatectl show -p Timezone --value 2>/dev/null || true)"

    if [[ "$code" != "fr" && -n "$current_timezone" ]]; then
        default_timezone="$current_timezone"
    fi

    timezone="$(prompt_default "$(tr_msg choose_timezone)" "$default_timezone")"

    lang_priority="$(language_priority_for_code "$code")"

    panel "$PMX_ORANGE" "$(tr_msg summary_title)" \
        "$(tr_msg label_pve_ui_language): ${BOLD}${code}${RESET}" \
        "$(tr_msg label_system_locale): ${BOLD}${locale_name}${RESET}" \
        "$(tr_msg label_language_priority): ${BOLD}${lang_priority}${RESET}" \
        "$(tr_msg label_timezone): ${BOLD}${timezone}${RESET}"
    echo

    printf "%b?%b %b%s ? [%s]%b : " "${PMX_AMBER}" "${RESET}" "${BOLD}" "$(tr_msg confirm_apply)" "$(tr_msg yes_no_default_no)" "${RESET}"
    read -r answer
    if ! is_yes "$answer"; then
        say_info "$(tr_msg cancelled)"
        pause
        return
    fi

    show_warning_and_confirm || { pause; return; }

    backup_dir="$(create_backup)"
    say_info "$(tr_msg backup_created): ${PMX_CYAN}${backup_dir}${RESET}"

    set_system_locale "$locale_name" "$lang_priority"
    say_ok "$(tr_msg locale_generated): $locale_name"
    say_ok "$(tr_msg locale_updated): LANG=$locale_name LANGUAGE=$lang_priority"
    say_ok "$(tr_msg profile_updated): $PROFILE_LOCALE_FILE"

    set_timezone_and_ntp "$timezone"
    say_ok "$(tr_msg timezone_updated): $timezone"
    say_ok "$(tr_msg ntp_enabled)"

    set_web_language "$code"
    say_ok "$(tr_msg web_language_updated): language: $code"

    say_info "$(tr_msg restart_proxy)"
    systemctl restart pveproxy.service

    echo
    say_ok "$(tr_msg config_applied)"
    say_info "$(tr_msg relogin_needed)"
    say_info "$(tr_msg backup_used): ${PMX_CYAN}${backup_dir}${RESET}"

    echo
    printf "%b?%b %b%s ? [%s]%b : " "${PMX_AMBER}" "${RESET}" "${BOLD}" "$(tr_msg reboot_question)" "$(tr_msg yes_no_default_no)" "${RESET}"
    read -r answer
    if is_yes "$answer"; then
        reboot
    else
        say_info "$(tr_msg reboot_later)"
    fi

    pause
}

show_status() {
    local dc_lang locale_value default_lc_all_value tz_value profile_status generated_status current_shell current_lc_all

    dc_lang="$(current_datacenter_language || true)"
    locale_value="$(current_default_locale || true)"
    default_lc_all_value="$(current_default_lc_all || true)"
    tz_value="$(timedatectl show -p Timezone --value 2>/dev/null || true)"
    current_shell="${LANG:-}"
    current_lc_all="${LC_ALL:-}"

    [[ -z "$dc_lang" ]] && dc_lang="$(tr_msg not_set)"
    [[ -z "$locale_value" ]] && locale_value="$(tr_msg not_set)"
    [[ -z "$default_lc_all_value" ]] && default_lc_all_value="$(tr_msg not_set)"
    [[ -z "$tz_value" ]] && tz_value="$(tr_msg not_set)"
    [[ -z "$current_shell" ]] && current_shell="$(tr_msg not_set)"
    [[ -z "$current_lc_all" ]] && current_lc_all="$(tr_msg not_set)"

    if [[ -f "$PROFILE_LOCALE_FILE" ]]; then
        profile_status="$PROFILE_LOCALE_FILE"
    else
        profile_status="$(tr_msg not_set)"
    fi

    if [[ -n "$locale_value" && "$locale_value" != "$(tr_msg not_set)" ]] && locale -a 2>/dev/null | grep -qi "^${locale_value%.UTF-8}\(\.utf8\|\.UTF-8\)$"; then
        generated_status="$(tr_msg status_ok)"
    else
        generated_status="$(tr_msg status_missing)"
    fi

    panel "$PMX_ORANGE" "$(tr_msg status_title)" \
        "/etc/pve/datacenter.cfg language: ${BOLD}${dc_lang}${RESET}" \
        "/etc/default/locale LANG: ${BOLD}${locale_value}${RESET}" \
        "/etc/default/locale LC_ALL: ${BOLD}${default_lc_all_value}${RESET}" \
        "$(tr_msg label_current_shell_lang): ${BOLD}${current_shell}${RESET}" \
        "$(tr_msg label_current_shell_lc_all): ${BOLD}${current_lc_all}${RESET}" \
        "$(tr_msg label_generated_locale): ${BOLD}${generated_status}${RESET}" \
        "$(tr_msg label_timezone): ${BOLD}${tz_value}${RESET}" \
        "$(tr_msg label_shell_profile): ${BOLD}${profile_status}${RESET}"
}

main_menu() {
    while true; do
        detect_lang
        show_banner

        printf " %b1)%b %s\n" "${PMX_ORANGE_SOFT}" "${RESET}" "$(tr_msg menu_apply)"
        printf " %b2)%b %s\n" "${PMX_ORANGE_SOFT}" "${RESET}" "$(tr_msg menu_restore_latest)"
        printf " %b3)%b %s\n" "${PMX_ORANGE_SOFT}" "${RESET}" "$(tr_msg menu_restore_select)"
        printf " %b4)%b %s\n" "${PMX_ORANGE_SOFT}" "${RESET}" "$(tr_msg menu_status)"
        printf " %b5)%b %s\n" "${PMX_ORANGE_SOFT}" "${RESET}" "$(tr_msg menu_languages)"
        printf " %b6)%b %s\n" "${PMX_ORANGE_SOFT}" "${RESET}" "$(tr_msg menu_backups)"
        printf " %b7)%b %s\n" "${PMX_ORANGE_SOFT}" "${RESET}" "$(tr_msg menu_quit)"
        echo

        local choice
        read -r -p "$(tr_msg choose_option) [1-7]: " choice
        echo

        case "$choice" in
            1) choose_and_apply ;;
            2) restore_latest; pause ;;
            3) interactive_restore_menu ;;
            4) show_status; pause ;;
            5) show_languages; pause ;;
            6) show_backups ;;
            7) say_info "$(tr_msg bye)"; exit 0 ;;
            *) say_err "$(tr_msg invalid_choice)"; pause ;;
        esac
    done
}

load_i18n
detect_lang
require_root
require_commands
require_files
main_menu
