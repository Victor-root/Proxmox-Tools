#!/usr/bin/env bash
set -euo pipefail

PATCH_PREFIX="/root/pve-default-language"
LOCALE_GEN_FILE="/etc/locale.gen"
DEFAULT_LOCALE_FILE="/etc/default/locale"
DATACENTER_CFG="/etc/pve/datacenter.cfg"
PROFILE_LOCALE_FILE="/etc/profile.d/proxmox-tools-locale.sh"
TIMEZONE_FILE="/etc/timezone"

# ------------------------------------------------------------
# Full script i18n
# - All user-facing text is stored below for all supported Proxmox UI languages.
# - The displayed language is detected from the server locale first.
# - If a language or a key is missing, English is used as fallback.
# ------------------------------------------------------------
declare -A I18N

load_i18n() {
    local lang key text
    while IFS='|' read -r lang key text; do
        [[ -z "${lang:-}" || -z "${key:-}" ]] && continue
        I18N["$lang:$key"]="$text"
    done <<'I18N_DATA'
